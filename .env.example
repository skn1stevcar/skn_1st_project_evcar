# ============================================================
#  .env.example — 이 파일을 .env 로 복사한 뒤 값을 채우세요.
#  .env 는 git 에서 제외되므로 절대 커밋하지 말 것.
#
#  cp .env.example .env   (Mac/Linux)
#  copy .env.example .env (Windows)
# ============================================================

# ----- MySQL 접속 정보 -----
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=비밀번호입력
DB_NAME=ev_infra
